{
  "package_name": "com.antigravity.audioplayer",
  "version": "1.0.0",
  "app_name": "Music Player",
  "icon": "music",
  "author": "Antigravity OS",
  "description": "A beautiful audio player that plays music from your virtual filesystem.",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Music Player</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <style>\n        body { background: #0f0c29; background: linear-gradient(to right, #24243e, #302b63, #0f0c29); color: white; font-family: 'Inter', sans-serif; margin: 0; height: 100vh; overflow: hidden; display: flex; flex-direction: column; }\n        .glass { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }\n        .record { width: 150px; height: 150px; border-radius: 50%; background: radial-gradient(circle, #111 40%, #000 70%); border: 4px solid #333; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }\n        .record::after { content: ''; width: 30px; height: 30px; background: #222; border-radius: 50%; border: 2px solid #555; }\n        .spin { animation: spin 4s linear infinite; }\n        @keyframes spin { 100% { transform: rotate(360deg); } }\n        ::-webkit-scrollbar { width: 6px; }\n        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }\n    </style>\n</head>\n<body>\n    <div class=\"flex-1 flex flex-col sm:flex-row h-full\">\n        <!-- Sidebar: Playlist -->\n        <div class=\"w-full sm:w-1/3 border-b sm:border-b-0 sm:border-r border-white/10 flex flex-col h-1/2 sm:h-full glass\">\n            <div class=\"p-4 border-b border-white/10 flex justify-between items-center\">\n                <h2 class=\"font-bold text-lg flex items-center gap-2\"><i data-lucide=\"list-music\"></i> Library</h2>\n                <button id=\"refresh-btn\" class=\"p-2 bg-white/10 rounded-full hover:bg-white/20 transition\"><i data-lucide=\"refresh-cw\" size=\"16\"></i></button>\n            </div>\n            <div id=\"playlist\" class=\"flex-1 overflow-y-auto p-2 space-y-1\">\n                <!-- Tracks will go here -->\n            </div>\n        </div>\n\n        <!-- Main: Player -->\n        <div class=\"w-full sm:w-2/3 flex flex-col items-center justify-center p-6 relative h-1/2 sm:h-full\">\n            <div class=\"absolute inset-0 opacity-20 pointer-events-none\" id=\"bg-visualizer\" style=\"background: radial-gradient(circle, var(--accent, #bb86fc) 0%, transparent 70%); transition: background 0.5s;\"></div>\n            \n            <div class=\"record mb-8\" id=\"record\"></div>\n            \n            <div class=\"text-center mb-8 w-full px-4\">\n                <h1 id=\"track-title\" class=\"text-2xl font-bold truncate mb-2\">No Track Selected</h1>\n                <p id=\"track-artist\" class=\"text-sm text-white/50 truncate\">Unknown Artist</p>\n            </div>\n            \n            <div class=\"w-full max-w-md px-4 glass rounded-3xl p-6 relative z-10\">\n                <div class=\"flex justify-between text-xs text-white/50 mb-2 font-mono\">\n                    <span id=\"time-curr\">0:00</span>\n                    <span id=\"time-total\">0:00</span>\n                </div>\n                <input type=\"range\" id=\"progress\" value=\"0\" min=\"0\" max=\"100\" class=\"w-full mb-6 accent-[#bb86fc] bg-white/10 rounded-lg appearance-none h-1.5 cursor-pointer\">\n                \n                <div class=\"flex justify-center items-center gap-6\">\n                    <button id=\"prev-btn\" class=\"text-white/70 hover:text-white transition\"><i data-lucide=\"skip-back\" size=\"24\"></i></button>\n                    <button id=\"play-btn\" class=\"w-14 h-14 flex items-center justify-center bg-[#bb86fc] text-black rounded-full hover:scale-105 transition shadow-[0_0_15px_rgba(187,134,252,0.4)]\">\n                        <i data-lucide=\"play\" size=\"28\" id=\"play-icon\" class=\"ml-1\"></i>\n                    </button>\n                    <button id=\"next-btn\" class=\"text-white/70 hover:text-white transition\"><i data-lucide=\"skip-forward\" size=\"24\"></i></button>\n                </div>\n            </div>\n        </div>\n    </div>\n    \n    <audio id=\"audio-element\"></audio>\n\n    <script>\n        lucide.createIcons();\n        const fs = window.parent.fs;\n        const audioEl = document.getElementById('audio-element');\n        const playBtn = document.getElementById('play-btn');\n        const playIcon = document.getElementById('play-icon');\n        const progress = document.getElementById('progress');\n        const timeCurr = document.getElementById('time-curr');\n        const timeTotal = document.getElementById('time-total');\n        const record = document.getElementById('record');\n        const trackTitle = document.getElementById('track-title');\n        const bgVis = document.getElementById('bg-visualizer');\n        const playlistEl = document.getElementById('playlist');\n\n        let tracks = [];\n        let currentIdx = -1;\n\n        function loadLibrary() {\n            if (!fs) {\n                playlistEl.innerHTML = '<div class=\"text-center text-white/50 mt-4 text-sm\">File System not found</div>';\n                return;\n            }\n            const exts = ['mp3', 'wav', 'ogg', 'm4a'];\n            tracks = [];\n            exts.forEach(ext => {\n                const results = fs.search('.' + ext);\n                results.forEach(r => tracks.push({\n                    path: r.path + (r.path === '/' ? '' : '/') + r.node.name,\n                    name: r.node.name,\n                    content: r.node.content\n                }));\n            });\n            \n            renderPlaylist();\n        }\n\n        function renderPlaylist() {\n            playlistEl.innerHTML = '';\n            if (tracks.length === 0) {\n                playlistEl.innerHTML = '<div class=\"text-center text-white/50 mt-8 text-sm flex flex-col items-center\"><i data-lucide=\"music-4\" size=\"32\" class=\"mb-2 opacity-30\"></i>No audio files found.<br>Import some .mp3 via Files app!</div>';\n                lucide.createIcons();\n                return;\n            }\n            tracks.forEach((t, i) => {\n                const div = document.createElement('div');\n                div.className = `p-3 rounded-xl cursor-pointer transition flex items-center gap-3 ${currentIdx === i ? 'bg-[#bb86fc]/20 border border-[#bb86fc]/30' : 'hover:bg-white/5 border border-transparent'}`;\n                div.innerHTML = `\n                    <div class=\"w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-accent\">\n                        <i data-lucide=\"${currentIdx === i ? 'bar-chart-2' : 'music'}\" size=\"14\"></i>\n                    </div>\n                    <div class=\"flex-1 truncate\">\n                        <div class=\"text-sm font-medium truncate ${currentIdx === i ? 'text-[#bb86fc]' : ''}\">${t.name}</div>\n                        <div class=\"text-[10px] text-white/40 truncate\">${t.path}</div>\n                    </div>\n                `;\n                div.onclick = () => playTrack(i);\n                playlistEl.appendChild(div);\n            });\n            lucide.createIcons();\n        }\n\n        function playTrack(idx) {\n            if (idx < 0 || idx >= tracks.length) return;\n            currentIdx = idx;\n            const t = tracks[idx];\n            \n            if (t.content && t.content.startsWith('data:')) {\n                audioEl.src = t.content;\n            } else {\n                alert('File is empty or corrupted. Please make sure you import proper .mp3 files.');\n                return;\n            }\n            \n            audioEl.play().catch(e => console.error(e));\n            trackTitle.textContent = t.name.replace(/\\.[^/.]+$/, \"\");\n            renderPlaylist();\n            updateColors();\n        }\n\n        function updateColors() {\n            const colors = ['#bb86fc', '#ef476f', '#06d6a0', '#118ab2', '#ffd166'];\n            const c = colors[Math.floor(Math.random() * colors.length)];\n            document.documentElement.style.setProperty('--accent', c);\n            bgVis.style.background = `radial-gradient(circle, ${c} 0%, transparent 70%)`;\n            playBtn.style.backgroundColor = c;\n            playBtn.style.boxShadow = `0 0 15px ${c}80`;\n            progress.style.accentColor = c;\n        }\n\n        function togglePlay() {\n            if (audioEl.paused) {\n                if (currentIdx === -1 && tracks.length > 0) playTrack(0);\n                else if (audioEl.src) audioEl.play();\n            } else {\n                audioEl.pause();\n            }\n        }\n\n        audioEl.onplay = () => {\n            playIcon.setAttribute('data-lucide', 'pause');\n            playIcon.classList.remove('ml-1');\n            record.classList.add('spin');\n            lucide.createIcons();\n        };\n\n        audioEl.onpause = () => {\n            playIcon.setAttribute('data-lucide', 'play');\n            playIcon.classList.add('ml-1');\n            record.classList.remove('spin');\n            lucide.createIcons();\n        };\n\n        audioEl.ontimeupdate = () => {\n            if (audioEl.duration) {\n                progress.value = (audioEl.currentTime / audioEl.duration) * 100;\n                timeCurr.textContent = fmt(audioEl.currentTime);\n                timeTotal.textContent = fmt(audioEl.duration);\n            }\n        };\n\n        audioEl.onended = () => {\n            document.getElementById('next-btn').click();\n        };\n\n        progress.oninput = () => {\n            if (audioEl.duration) {\n                audioEl.currentTime = (progress.value / 100) * audioEl.duration;\n            }\n        };\n\n        document.getElementById('play-btn').onclick = togglePlay;\n        document.getElementById('prev-btn').onclick = () => playTrack(currentIdx - 1 < 0 ? tracks.length - 1 : currentIdx - 1);\n        document.getElementById('next-btn').onclick = () => playTrack((currentIdx + 1) % tracks.length);\n        document.getElementById('refresh-btn').onclick = loadLibrary;\n\n        function fmt(s) {\n            if (isNaN(s)) return '0:00';\n            const m = Math.floor(s / 60);\n            const sec = Math.floor(s % 60);\n            return m + ':' + (sec < 10 ? '0' : '') + sec;\n        }\n\n        // Init\n        loadLibrary();\n    </script>\n</body>\n</html>"
}
